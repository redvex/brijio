{
  "manifest_version": 2,
  "name": "BrowserBridge",
  "version": "0.0.0",
  "description": "User-controlled bridge between Safari and AI agents.",
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "BrowserBridge"
  },
  "permissions": ["*://*/*"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"]
    }
  ]
}