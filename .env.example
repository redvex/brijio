# Brijio Configuration
# Run `pnpm dev` to start servers — it will generate tokens automatically.
# Edit this file only for manual overrides.

# WebSocket server
WEBSOCKET_HOST=0.0.0.0
WEBSOCKET_PORT=8787
BRIJIO_WS_URL=ws://127.0.0.1:8787
BRIJIO_REQUEST_TIMEOUT_MS=5000

# Tokens - auto-generated by `pnpm dev`, or run `pnpm token` for manual generation
BRIJIO_PAIRING_TOKEN=replace-with-generated-token
BRIJIO_BROWSER_INSTANCE_ID=

# Backwards-compatible BrowserBridge aliases are still accepted during the transition.
# BROWSERBRIDGE_PAIRING_TOKEN=replace-with-generated-token
# BROWSERBRIDGE_WEBSOCKET_URL=ws://127.0.0.1:8787
# BROWSERBRIDGE_REQUEST_TIMEOUT_MS=5000

# MCP HTTP server
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8788
MCP_HTTP_PATH=/mcp
MCP_HTTP_AUTH_TOKEN=replace-with-generated-mcp-token

# CORS origins (comma-separated, e.g. http://localhost:3000)
MCP_HTTP_ALLOWED_ORIGINS=

# Test page (Docker only, not started by `pnpm dev`)
TEST_PAGE_PORT=8080