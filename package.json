{
  "name": "browserbridge",
  "version": "0.0.0",
  "private": true,
  "description": "User-controlled bridge between browser extensions and AI agents.",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "dev": "pnpm -r --parallel dev",
    "format:md": "prettier --write \"**/*.md\"",
    "lint": "pnpm lint:ts && pnpm lint:md",
    "lint:md": "prettier --check \"**/*.md\"",
    "lint:ts": "XDG_CACHE_HOME=.cache ts-standard \"**/*.ts\"",
    "precommit": "scripts/pre-commit",
    "test": "pnpm -r test && node --test scripts/*.test.mjs"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "ts-standard": "^12.0.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
