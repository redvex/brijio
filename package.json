{
  "name": "brijio",
  "version": "0.2.0",
  "private": true,
  "description": "Brijio gives AI agents controlled, user-approved browser access.",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "brijio": "node scripts/brijio-token.mjs",
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "dev": "node scripts/dev.mjs",
    "dev:ws": "tsx watch servers/websocket/src/index.ts",
    "dev:mcp": "tsx watch servers/mcp/src/index.ts",
    "format:md": "prettier --write \"**/*.md\"",
    "lint": "pnpm lint:ts && pnpm lint:md",
    "lint:md": "prettier --check \"**/*.md\"",
    "lint:ts": "XDG_CACHE_HOME=.cache ts-standard \"**/*.ts\"",
    "precommit": "scripts/pre-commit",
    "serve:test-pages": "node scripts/build-pages-site.mjs .pages-site && npx serve .pages-site",
    "test": "pnpm -r test && node --test scripts/*.test.mjs",
    "token": "node scripts/brijio-token.mjs"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "ts-standard": "^12.0.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
